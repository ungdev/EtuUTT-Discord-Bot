{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "helpers:pinGitHubActionDigests"
    ],
    "timezone": "Europe/Paris",
    "schedule": [ "* 22-23 * * 0", "* 0-5 * * 1" ],
    "prHourlyLimit": 0,
    "packageRules": [
        {
            "matchManagers": [ "pep621" ],
            "matchDepTypes": [ "project.dependencies" ],
            "matchUpdateTypes": [ "major" ],
            "groupName": "Python (prod-major)",
            "groupSlug": "python-prod-major",
            "commitMessagePrefix": "chore(deps-major): "
        }, {
            "matchManagers": [ "pep621" ],
            "matchDepTypes": [ "project.dependencies" ],
            "matchUpdateTypes": [ "patch", "minor" ],
            "groupName": "Python (prod-minor)",
            "groupSlug": "python-prod-minor",
            "commitMessagePrefix": "chore(deps-minor): ",
            "automerge": true
        }, {
            "matchManagers": [ "pep621", "pre-commit" ],
            "matchJsonata": [
                "depType = 'dependency-groups' and managerData.depGroup = 'dev'",
                "depType = 'repository'"
            ],
            "groupName": "Python (dev)",
            "groupSlug": "python-dev",
            "commitMessagePrefix": "chore(deps-dev): ",
            "automerge": true
        }, {
            "matchManagers": [ "pep621" ],
            "matchJsonata": [ "depType = 'dependency-groups' and managerData.depGroup = 'docs'" ],
            "groupName": "Python (docs)",
            "groupSlug": "python-docs",
            "commitMessagePrefix": "chore(deps-docs): ",
            "automerge": true
        }, {
            "matchManagers": [ "github-actions" ],
            "groupName": "GitHub Actions",
            "commitMessagePrefix": "chore(deps-ga): ",
            "automerge": true
        }, {
            "matchManagers": [ "dockerfile" ],
            "groupName": "Docker images",
            "commitMessagePrefix": "chore(deps-docker): "
        }
    ],
    "commitMessageAction": "update",
    "commitMessageTopic": "{{depName}}",
    "enabledManagers": [
        "pep621",
        "github-actions",
        "dockerfile",
        "pre-commit"
    ],
    "lockFileMaintenance": {
        "enabled": true
    },
    "platformAutomerge": true,
    "pre-commit": {
        "enabled": true
    }
}
